# ── Database ───────────────────────────────────────────────────────────────────
# Docker: service-name "postgres" resolves inside the compose network.
DATABASE_URL=postgresql+asyncpg://AutoSteer:AutoSteer_dev@postgres:5432/AutoSteer

# ── Redis ──────────────────────────────────────────────────────────────────────
# Docker: service-name "redis" resolves inside the compose network.
REDIS_URL=redis://redis:6379/0



# LLM providers

ANTHROPIC_API_KEY=sk-ant-xxx

OPENAI_API_KEY=sk-xxx

DEFAULT_LLM_PROVIDER=openai

DEFAULT_LLM_MODEL=gpt-4o-mini

# Local LLM (offline/air-gapped — requires GGUF model file)

LLAMA_CPP_MODEL_PATH=

LLAMA_CPP_GPU_LAYERS=0

LLAMA_CPP_CONTEXT_SIZE=4096

# Local TTS (offline — requires `pip install kokoro`)

KOKORO_VOICE=af_heart



# Auth (optional)

AutoSteer_api_key=

CLERK_SECRET_KEY=

CLERK_PUBLISHABLE_KEY=



# Workflow cost caps

MAX_WORKFLOW_AGENTS=10

MAX_PARALLEL=3

MAX_CONCURRENT_DEPARTMENTS=5



# Integration platform

INTEGRATION_ENCRYPTION_KEY=dev-change-me-in-production-use-openssl-rand



# Phase A — global integration fallbacks (workspace tokens stored encrypted in DB)

TAVILY_API_KEY=

SLACK_BOT_TOKEN=

GITHUB_TOKEN=

NOTION_TOKEN=



# Phase B

LINEAR_API_KEY=

GOOGLE_SERVICE_ACCOUNT_JSON=



# Phase C — revenue & support

HUBSPOT_ACCESS_TOKEN=

APOLLO_API_KEY=

POSTHOG_API_KEY=

TYPEFORM_ACCESS_TOKEN=

STRIPE_SECRET_KEY=

INTERCOM_ACCESS_TOKEN=

ZENDESK_API_TOKEN=

SENTRY_AUTH_TOKEN=



# Email send (beta — requires EMAIL_SEND_ENABLED=true + approved=true in tool call)

EMAIL_SEND_ENABLED=false

EMAIL_PROVIDER=resend

EMAIL_FROM_ADDRESS=

RESEND_API_KEY=

POSTMARK_API_KEY=



# Phase D — AI ops

E2B_API_KEY=

WANDB_API_KEY=



# Phase E — knowledge & ops

ZAPIER_WEBHOOK_URL=

DOCUSIGN_ACCESS_TOKEN=

DOCUSIGN_TEMPLATE_ID=

DOCUSIGN_TEMPLATE_URL=

FIGMA_ACCESS_TOKEN=

GOOGLE_PAGESPEED_API_KEY=



# Hosted billing (Stripe checkout links from Stripe Dashboard)

STRIPE_CHECKOUT_URL_STARTER=

STRIPE_CHECKOUT_URL_TEAM=

STRIPE_WEBHOOK_SECRET=



# File uploads directory (relative to backend/)

UPLOADS_DIR=uploads



DEBUG=true

