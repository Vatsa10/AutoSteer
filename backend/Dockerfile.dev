# =============================================================================
# Raah Backend — Development Dockerfile
# =============================================================================
# Lightweight image used only in dev mode (docker-compose.dev.yml).
# Source code is mounted as a volume, so we only need the runtime + deps
# installed into the image.  The --reload flag is set in the CMD.
# =============================================================================

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies (these rarely change, so Docker caches this layer).
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[dev]"

# Source code is mounted at runtime via docker-compose.dev.yml volumes.
# We still COPY an empty placeholder so uvicorn can start before the mount.
COPY . .

EXPOSE 8000

CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
